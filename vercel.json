{
    "version": 2,
    "builds": [
        {
            "src": "index.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/index.js"
        },
        {
            "src": "/",
            "dest": "/public/home.html"
        },
        {
            "src": "/(.*\\.(html|css|js|png|jpg|ico))",
            "dest": "/public/$1"
        }
    ]
}